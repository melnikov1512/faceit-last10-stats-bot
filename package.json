{
    "name": "telegram-bot-gc-function",
    "version": "1.0.0",
    "main": "index.js",
    "scripts": {
        "start": "node index.js",
        "set-webhook": "node scripts/set-webhook.js",
        "test-notify": "node scripts/test-notify.js",
        "test-notify-finish": "node scripts/test-notify-finish.js",
        "dev": "concurrently --names \"ngrok,server\" --prefix-colors \"cyan,green\" \"ngrok http --url=huddlingly-shirty-chantal.ngrok-free.dev 8080\" \"node index.js\"",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage"
    },
    "engines": {
        "node": "20"
    },
    "dependencies": {
        "@google-cloud/firestore": "^8.3.0",
        "@napi-rs/canvas": "^0.1.97",
        "axios": "^1.13.6",
        "dotenv": "^17.3.1",
        "express": "^4.18.2"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "concurrently": "^9.2.1",
        "jest": "^29.7.0"
    },
    "jest": {
        "testEnvironment": "node",
        "testMatch": [
            "**/tests/**/*.test.js"
        ],
        "coverageDirectory": "coverage",
        "collectCoverageFrom": [
            "src/**/*.js",
            "!src/assets/**"
        ],
        "coverageReporters": [
            "text",
            "lcov",
            "html"
        ]
    }
}
